"use client";

import { useEffect, useState } from "react";
import Sidebar from "@/components/Sidebar";
import Header from "@/components/Header";
import StatCard from "@/components/StatCard";
import AdminCard from "@/components/AdminCard";
import AuthGuard from "@/components/AuthGuard";
import {
  Users,
  Car,
  TrendingUp,
  Clock,
  Plus,
  CheckCircle2,
  Calendar
} from "lucide-react";
import Link from "next/link";

interface DashboardInquiry {
  id: string;
  name: string;
  subject: string;
  status: "New" | "Read" | "Replied";
}

function Dashboard() {
  const [recentInquiries, setRecentInquiries] = useState<DashboardInquiry[]>([]);

  useEffect(() => {
    const fetchRecent = async () => {
      try {
        const res = await fetch("/api/inquiries");
        if (!res.ok) return;
        const data: any[] = await res.json();
        const mapped: DashboardInquiry[] = data
          .slice(0, 4)
          .map((inq) => ({
            id: inq.id,
            name: inq.name,
            subject: inq.subject,
            status: inq.status,
          }));
        setRecentInquiries(mapped);
      } catch (e) {
        console.error("Failed to load dashboard inquiries", e);
      }
    };

    fetchRecent();
  }, []);

  return (
    <div className="min-h-screen bg-secondary/50 font-sans">
      <Sidebar />

      <main className="lg:pl-72 px-4 md:px-8 py-8 transition-all duration-300">
        <Header title="Overview" />

        {/* Stats Grid - Simplified to 3 core stats for mobile/simplicity */}
        <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 mb-8">
          <StatCard
            label="Revenue"
            value="₹4.2L"
            trend="+12%"
            icon={TrendingUp}
          />
          <StatCard
            label="Bookings"
            value="24"
            trend="+3%"
            icon={Calendar}
          />
          <StatCard
            label="Total Services"
            value="14"
            trend="Active"
            icon={Car}
            trendUp={true}
          />
        </div>

        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
          {/* Simplified Recent Bookings */}
          <div className="lg:col-span-2">
            <AdminCard
              title="Recent Inquiries"
              headerAction={
                <Link href="/inquiries" className="bg-primary text-white p-3 sm:px-6 sm:py-3 rounded-xl font-bold hover:bg-blue-600 shadow-lg shadow-primary/20 transition-all flex items-center gap-2 text-sm text-center">
                  View All
                </Link>
              }
            >
              <div className="overflow-x-auto -mx-6 px-6">
                <table className="w-full text-left min-w-[500px]">
                  <thead>
                    <tr className="border-b border-brand-border">
                      <th className="py-4 text-xs font-bold text-foreground/40 uppercase tracking-widest">User</th>
                      <th className="py-4 text-xs font-bold text-foreground/40 uppercase tracking-widest">Inquiry Type</th>
                      <th className="py-4 text-xs font-bold text-foreground/40 uppercase tracking-widest text-right">Status</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-brand-border/50">
                    {recentInquiries.map((row) => {
                      const color =
                        row.status === "New"
                          ? "text-blue-500"
                          : row.status === "Replied"
                          ? "text-green-500"
                          : "text-zinc-500";
                      return (
                        <tr key={row.id} className="group hover:bg-secondary/30 transition-colors">
                          <td className="py-4">
                            <div className="font-bold text-accent">{row.name}</div>
                          </td>
                          <td className="py-4">
                            <span className="text-sm font-bold text-foreground/60">
                              {row.subject}
                            </span>
                          </td>
                          <td className="py-4 text-right">
                            <div
                              className={`inline-flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-wider ${color}`}
                            >
                              {row.status}
                            </div>
                          </td>
                        </tr>
                      );
                    })}
                    {recentInquiries.length === 0 && (
                      <tr>
                        <td
                          colSpan={3}
                          className="py-6 text-center text-xs font-bold text-foreground/40"
                        >
                          No inquiries found.
                        </td>
                      </tr>
                    )}
                  </tbody>
                </table>
              </div>
            </AdminCard>
          </div>

          {/* Quick Actions / Tips */}
          <div className="space-y-6">
            <AdminCard title="Quick Actions">
              <div className="grid grid-cols-1 gap-3">
                <button className="flex items-center gap-3 p-4 bg-secondary/50 rounded-xl hover:bg-secondary transition-all text-left">
                  <div className="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-primary border border-brand-border">
                    <Plus size={20} />
                  </div>
                  <div>
                    <p className="text-sm font-bold text-accent">Create Booking</p>
                    <p className="text-[10px] text-foreground/40 font-medium whitespace-nowrap">Schedule a new visit</p>
                  </div>
                </button>
                <button className="flex items-center gap-3 p-4 bg-secondary/50 rounded-xl hover:bg-secondary transition-all text-left">
                  <div className="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-primary border border-brand-border">
                    <Users size={20} />
                  </div>
                  <div>
                    <p className="text-sm font-bold text-accent">Add Customer</p>
                    <p className="text-[10px] text-foreground/40 font-medium whitespace-nowrap">Grow your database</p>
                  </div>
                </button>
              </div>
            </AdminCard>

            <div className="bg-primary rounded-2xl p-6 text-white text-center">
              <h3 className="text-lg font-serif font-bold mb-1">Busy Day?</h3>
              <p className="text-white/70 text-xs font-medium mb-4">You have 8 cars scheduled for today.</p>
              <button className="bg-white text-primary px-6 py-2.5 rounded-xl font-bold hover:bg-zinc-100 transition-all text-xs w-full">
                View Schedule
              </button>
            </div>
          </div>
        </div>
      </main>
    </div>
  );
}

export default function DashboardPage() {
  return (
    <AuthGuard>
      <Dashboard />
    </AuthGuard>
  );
}
